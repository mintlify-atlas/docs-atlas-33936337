  "keyFeatures": [
    "Thread-safe async logging via dedicated queue",
    "Granular log levels with emoji-first output",
    "Category-based filtering and organization",
    "Pluggable sinks for custom log destinations",
    "@Loggable macro for automatic logger generation",
    "Custom formatting support",
    "AsyncStream integration for modern Swift",
    "Native os.log integration with OSLogType mapping"
